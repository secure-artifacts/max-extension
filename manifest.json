{
  "manifest_version": 3,
  "name": "MAX 出勤记录器",
  "version": "2.0.0",
  "description": "在 MAX 网页版按用户 ID 静默记录参会者在线时长，点击扩展图标在新标签页查看每人上线时间（含自己）。",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://max.ru/*",
    "https://*.max.ru/*",
    "https://web.max.ru/*"
  ],
  "action": {
    "default_title": "MAX 出勤记录器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*",
        "https://web.max.ru/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*",
        "https://web.max.ru/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*",
        "https://web.max.ru/*"
      ]
    }
  ]
}
