{
  "manifest_version": 3,
  "name": "MAX 出勤记录器",
  "version": "1.2.0",
  "description": "在 MAX 网页版按用户 ID 自动记录参会者上线/下线与在线时长，支持悬浮窗、历史记录与导出。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://max.ru/*",
    "https://*.max.ru/*",
    "https://web.max.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MAX 出勤记录器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*",
        "https://web.max.ru/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*",
        "https://web.max.ru/*"
      ]
    }
  ]
}
